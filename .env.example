NODE_ENV=development
DATABASE_URL=postgresql://CHANGE_USER:CHANGE_PASSWORD@localhost:5432/appcampo
AUTH_API_PORT=3001
AUTH_API_HOST=0.0.0.0
AUTH_API_TARGET=http://localhost:3001
APP_BASE_URL=http://localhost:5173
# Web/desktop dev can stay empty (Vite proxy). For Android emulator use: http://10.0.2.2:3001
VITE_API_BASE_URL=
AUTH_COOKIE_NAME=appcampo_sid
SESSION_TTL_HOURS=24
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
PG_SSLMODE=disable
AUTH_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost,ionic://localhost
S3_ENDPOINT=https://us-sea-1.linodeobjects.com
S3_REGION=us-sea-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_FORCE_PATH_STYLE=false
