NODE_ENV=production

POSTGRES_DB=appcampo
POSTGRES_USER=appcampo
POSTGRES_PASSWORD=change-this-password

DATABASE_URL=postgresql://appcampo:change-this-password@db:5432/appcampo

AUTH_API_PORT=3001
AUTH_API_HOST=0.0.0.0
AUTH_API_TARGET=https://field.erione.com
APP_BASE_URL=https://field.erione.com
AUTH_ALLOWED_ORIGINS=https://field.erione.com
AUTH_COOKIE_NAME=appcampo_sid
SESSION_TTL_HOURS=24
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
PG_SSLMODE=disable

VITE_API_BASE_URL=https://field.erione.com

S3_ENDPOINT=https://example-object-storage.com
S3_REGION=example-region-1
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=change-me
S3_FORCE_PATH_STYLE=false
